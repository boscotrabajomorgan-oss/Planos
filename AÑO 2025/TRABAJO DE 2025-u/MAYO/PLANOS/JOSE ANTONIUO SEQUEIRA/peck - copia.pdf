<!--survey report-->
<html>
<head>
    <title>Reporte HTML</title>
    <meta charset="UTF-8">
</head>

<body>


<style>
    p,h1,h2{padding:0px;margin:0px}
    body{
        width: 90%;
        margin: 0px auto;
        padding: 10px 20px
    }
    h1,h2{
        margin:10px 0px 5px 0px;
        text-align: center;
    }

    h3,h4{
        margin:8px 0px 4px 0px;
    }

    .app{
        padding:5px 0px;
        text-align:right;
        border-bottom:1px solid #888888;
    }

    .properties{width: 100%}
    .properties th { text-align:left; background-color: whitesmoke;  }
    .properties td { }
    .properties td, .properties th
      { padding: 2px 3px 2px 3px; border-bottom: 1px solid #888888; }

     .row td, .row.th{
        padding: 2px;
     }

     .row td:nth-child(1){width: 200px}
     .row td:nth-child(2){font-style:oblique;}

     .coo{
        margin-top:5px;
     }

     .b{
        margin-top:10px;
     }
     .pp, .bt{
        width:55%;
     }

     .num{text-align:right !important;}


</style>

<h1>Reporte HTML</h1>
<p class="app">Survey Master:&nbsp;V3.4.1.0</p>
<h3>1. Info Proyecto</h3>
